// World Cup Onchain Prediction Leaderboard - data model.
//
// Local dev uses SQLite for zero-setup. Models avoid SQLite-only features so the
// same schema works on PostgreSQL in production (switch `provider` + DATABASE_URL).
// JSON-shaped fields are stored as text (stringified JSON) for DB portability; the
// app reads/writes them through helpers in src/lib/json.ts.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  username     String   @unique
  xHandle      String?
  email        String?  @unique
  rewardWallet String?
  isAdmin      Boolean  @default(false)
  createdAt    DateTime @default(now())

  identities         AuthIdentity[]
  predictions        Prediction[]
  revertPayments     RevertPayment[]
  leaderboardEntries LeaderboardEntry[]
}

/// A single login method bound to a user. One user can link multiple methods.
model AuthIdentity {
  id         String   @id @default(cuid())
  provider   String // "x" | "email" | "wallet"
  providerId String // x user id | email address | wallet pubkey (base58)
  userId     String
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerId])
  @@index([userId])
}

/// Short-lived one-time code for email login.
model EmailOtp {
  id        String   @id @default(cuid())
  email     String
  codeHash  String
  expiresAt DateTime
  consumed  Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([email])
}

/// Short-lived nonce a wallet must sign to prove ownership.
model WalletNonce {
  id        String   @id @default(cuid())
  pubkey    String
  nonce     String   @unique
  expiresAt DateTime
  consumed  Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([pubkey])
}

model Match {
  id                 String   @id @default(cuid())
  externalId         String?  @unique // id from the sports API, for settlement matching
  homeTeam           String
  awayTeam           String
  kickoffAt          DateTime
  stage              String   @default("Group Stage")
  status             String   @default("scheduled") // scheduled | live | finished | settled
  result             String? // JSON: { homeGoals, awayGoals, corners, ... }
  resultCommitmentTx String? // Solana tx signature of the on-chain result hash
  settledAt          DateTime?
  createdAt          DateTime @default(now())

  predictions Prediction[]

  @@index([status])
  @@index([kickoffAt])
}

/// A predictable category (exact score, corners, etc). Weighting lives here as a
/// base value and can be overridden per track via TrackCategory.
model Category {
  id         String  @id @default(cuid())
  key        String  @unique // exact_score | correct_result | total_goals | corners | btts
  label      String
  baseWeight Int
  schema     String // JSON describing the expected prediction value shape (used by UI + validation)
  active     Boolean @default(true)
  sortOrder  Int     @default(0)

  trackCategories TrackCategory[]
  predictions     Prediction[]
}

/// A competition track. The main track is always present; sponsors get their own
/// tracks with a category subset, custom weights, a date window, and branding.
model Track {
  id        String    @id @default(cuid())
  slug      String    @unique
  name      String
  sponsor   String?
  branding  String? // JSON: { color, logoUrl, tagline }
  startAt   DateTime?
  endAt     DateTime?
  isMain    Boolean   @default(false)
  active    Boolean   @default(true)
  createdAt DateTime  @default(now())

  trackCategories    TrackCategory[]
  predictions        Prediction[]
  leaderboardEntries LeaderboardEntry[]
}

/// Join row enabling a category within a track and overriding its weight.
model TrackCategory {
  id         String  @id @default(cuid())
  trackId    String
  categoryId String
  weight     Int
  enabled    Boolean @default(true)

  track    Track    @relation(fields: [trackId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([trackId, categoryId])
  @@index([trackId])
}

model Prediction {
  id            String   @id @default(cuid())
  userId        String
  matchId       String
  categoryId    String
  trackId       String
  value         String // JSON: the user's prediction for this category
  pointsAwarded Int? // null until settled
  status        String   @default("open") // open | locked | settled
  editUnlocked  Boolean  @default(false) // set true by a verified revert payment, consumed on edit
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  match    Match    @relation(fields: [matchId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  track    Track    @relation(fields: [trackId], references: [id], onDelete: Cascade)

  revertPayments RevertPayment[]

  // One prediction per user, per match, per category, per track.
  @@unique([userId, matchId, categoryId, trackId])
  @@index([matchId])
  @@index([trackId])
}

/// An on-chain payment that unlocks a single edit of an already-placed prediction.
model RevertPayment {
  id           String    @id @default(cuid())
  predictionId String
  userId       String
  currency     String // SOL | USDC
  txSignature  String    @unique
  amount       String // raw amount (lamports for SOL, base units for USDC)
  verifiedAt   DateTime?
  createdAt    DateTime  @default(now())

  prediction Prediction @relation(fields: [predictionId], references: [id], onDelete: Cascade)
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([predictionId])
}

/// Key-value store for app-wide settings (e.g. last fixture sync timestamp).
model AppMeta {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

/// Materialized leaderboard position per user per track.
model LeaderboardEntry {
  id          String   @id @default(cuid())
  userId      String
  trackId     String
  totalPoints Int      @default(0)
  rank        Int?
  updatedAt   DateTime @updatedAt

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  track Track @relation(fields: [trackId], references: [id], onDelete: Cascade)

  @@unique([userId, trackId])
  @@index([trackId])
}
